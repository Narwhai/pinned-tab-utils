{
	"name": "pinned-tab-utils",
	"version": "1.0.0",
	"description": "Automatically moves pinned tabs to the left side of the tab bar, mimicking browser behaviour.",
	"main": "main.js",
	"type": "module",
	"scripts": {
		"dev": "node esbuild.config.mjs",
		"build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production",
		"lint": "eslint ."
	},
	"keywords": ["obsidian", "pinned-tabs", "tab-order"],
	"license": "0BSD",
	"devDependencies": {
		"@types/node": "^16.11.6",
		"esbuild": "0.25.5",
		"obsidian": "latest",
		"@eslint/js": "9.30.1",
		"eslint-plugin-obsidianmd": "0.1.9",
		"globals": "14.0.0",
		"typescript": "^5.8.3",
		"typescript-eslint": "8.35.1",
		"tslib": "2.4.0",
		"jiti": "2.6.1"
	}
}